<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>TaskTracker — Sign In / Register</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root{
    --navy:#1F2A44;
    --navy-deep:#161E33;
    --paper:#EEF1F6;
    --card:#FFFFFF;
    --amber:#F2A93B;
    --amber-deep:#D9901F;
    --teal:#3EC1B3;
    --text:#1F2A44;
    --muted:#6B7280;
    --line:#E2E6EE;
    --danger:#E0555A;
  }

  *{box-sizing:border-box;}

  body{
    margin:0;
    background:var(--paper);
    background-image:
      radial-gradient(var(--line) 1px, transparent 1px);
    background-size:22px 22px;
    font-family:'Inter',sans-serif;
    color:var(--text);
    padding:48px 20px;
  }

  .wrap{
    max-width:960px;
    margin:0 auto;
  }

  .brand{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:28px;
  }

  .brand .mark{
    width:34px;height:34px;border-radius:9px;
    background:var(--navy);
    display:flex;align-items:center;justify-content:center;
  }
  .brand .mark svg{width:18px;height:18px;}

  .brand h1{
    font-family:'Space Grotesk',sans-serif;
    font-size:20px;
    font-weight:700;
    margin:0;
    letter-spacing:.2px;
  }

  /* ---------- Split auth panel ---------- */

  .auth-panel{
    display:grid;
    grid-template-columns:0.85fr 1fr;
    background:var(--card);
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 20px 45px -20px rgba(31,42,68,.35);
    border:1px solid var(--line);
    animation:riseIn .5s ease both;
  }

  @@keyframes riseIn{
    from{opacity:0;transform:translateY(10px);}
    to{opacity:1;transform:translateY(0);}
  }

  @@media (max-width:820px){
    .auth-panel{grid-template-columns:1fr;}
  }

  /* Left: Login */
  .login-side{
    background:
      radial-gradient(circle at 15% 10%, rgba(242,169,59,.18), transparent 45%),
      linear-gradient(165deg, var(--navy) 0%, var(--navy-deep) 100%);
    color:#fff;
    padding:44px 36px;
    display:flex;
    flex-direction:column;
    position:relative;
  }

  .login-side::before{
    content:"";
    position:absolute;
    inset:0;
    background-image:
      linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px);
    background-size:26px 26px;
    mask-image:linear-gradient(180deg, rgba(0,0,0,.6), transparent 70%);
    pointer-events:none;
  }

  .login-eyebrow{
    font-size:11px;
    letter-spacing:1.6px;
    text-transform:uppercase;
    color:var(--amber);
    font-weight:700;
    margin-bottom:6px;
    position:relative;
  }

  .login-side h2{
    font-family:'Space Grotesk',sans-serif;
    font-size:26px;
    margin:0 0 6px;
    position:relative;
  }

  .login-side p.sub{
    color:#C7CEDD;
    font-size:13.5px;
    margin:0 0 28px;
    position:relative;
    line-height:1.5;
  }

  .field{
    margin-bottom:16px;
    position:relative;
  }

  .field label{
    display:block;
    font-size:12.5px;
    font-weight:600;
    margin-bottom:6px;
    color:#DCE1EC;
  }

  .login-side input{
    width:100%;
    padding:11px 13px;
    border-radius:10px;
    border:1px solid rgba(255,255,255,.16);
    background:rgba(255,255,255,.06);
    color:#fff;
    font-size:14px;
    font-family:inherit;
    outline:none;
    transition:border-color .15s, background .15s;
  }
  .login-side input::placeholder{color:#8B93AA;}
  .login-side input:focus{
    border-color:var(--amber);
    background:rgba(255,255,255,.1);
  }

  .btn-login{
    margin-top:6px;
    width:100%;
    padding:12px;
    border:none;
    border-radius:10px;
    background:var(--amber);
    color:var(--navy-deep);
    font-weight:700;
    font-size:14.5px;
    cursor:pointer;
    transition:transform .12s ease, background .15s ease;
    font-family:inherit;
  }
  .btn-login:hover{background:var(--amber-deep); transform:translateY(-1px);}
  .btn-login:active{transform:translateY(0);}

  .login-error{
    color:#FF9C9C;
    font-size:13px;
    margin-top:10px;
    min-height:16px;
  }

  .login-foot{
    margin-top:auto;
    padding-top:26px;
    display:flex;
    align-items:center;
    gap:8px;
    font-size:12px;
    color:#8B93AA;
    position:relative;
  }
  .login-foot svg{width:14px;height:14px;flex:none;}

  /* Right: Register */
  .register-side{
    padding:44px 40px;
  }

  .register-side .login-eyebrow{color:var(--amber-deep);}

  .register-side h2{
    font-family:'Space Grotesk',sans-serif;
    font-size:24px;
    margin:0 0 6px;
    color:var(--navy);
  }

  .register-side p.sub{
    color:var(--muted);
    font-size:13.5px;
    margin:0 0 24px;
  }

  .required{color:var(--danger);}

  .register-side .field label{
    color:var(--navy);
  }

  .register-side input,
  .register-side textarea{
    width:100%;
    padding:11px 13px;
    border-radius:10px;
    border:1.5px solid var(--line);
    background:var(--paper);
    color:var(--text);
    font-size:14px;
    font-family:inherit;
    outline:none;
    transition:border-color .15s, box-shadow .15s;
    resize:vertical;
  }
  .register-side input:focus,
  .register-side textarea:focus{
    border-color:var(--teal);
    box-shadow:0 0 0 3px rgba(62,193,179,.15);
  }

  .error{
    color:var(--danger);
    font-size:12.5px;
    margin-top:5px;
    min-height:15px;
  }

  .row2{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:14px;
  }

  .btn-register{
    width:100%;
    margin-top:6px;
    padding:12px;
    border:none;
    border-radius:10px;
    background:var(--navy);
    color:#fff;
    font-weight:700;
    font-size:14.5px;
    cursor:pointer;
    transition:transform .12s ease, background .15s ease;
    font-family:inherit;
  }
  .btn-register:hover{background:var(--navy-deep); transform:translateY(-1px);}

  /* ---------- Table section ---------- */

  .table-section{
    margin-top:44px;
  }

  .table-head{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    margin-bottom:14px;
  }

  .table-head h3{
    font-family:'Space Grotesk',sans-serif;
    font-size:18px;
    margin:0;
  }

  .table-head span{
    font-size:12.5px;
    color:var(--muted);
  }

  .table-card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:16px;
    overflow:hidden;
    box-shadow:0 10px 30px -18px rgba(31,42,68,.25);
  }

  table{
    width:100%;
    border-collapse:collapse;
    font-size:13.5px;
  }

  thead tr{background:var(--navy); color:#fff;}
  thead th{
    text-align:left;
    padding:12px 16px;
    font-weight:600;
    font-family:'Space Grotesk',sans-serif;
    font-size:12.5px;
    letter-spacing:.3px;
    text-transform:uppercase;
  }

  tbody td{
    padding:12px 16px;
    border-top:1px solid var(--line);
    color:var(--text);
  }

  tbody tr:hover{background:#F7F9FC;}

  .empty-row td{
    text-align:center;
    padding:30px;
    color:var(--muted);
  }

  .btn-sm{
    border:none;
    border-radius:7px;
    padding:6px 12px;
    font-size:12.5px;
    font-weight:600;
    cursor:pointer;
    font-family:inherit;
    transition:opacity .15s;
  }
  .btn-sm:hover{opacity:.85;}
  .btn-edit{background:rgba(242,169,59,.18); color:var(--amber-deep);}
  .btn-del{background:rgba(224,85,90,.12); color:var(--danger); margin-left:6px;}

  .toast{
    position:fixed;
    top:20px; left:50%;
    transform:translateX(-50%) translateY(-14px);
    background:var(--navy);
    color:#fff;
    padding:11px 20px;
    border-radius:10px;
    font-size:13.5px;
    font-weight:600;
    box-shadow:0 12px 30px -10px rgba(0,0,0,.4);
    opacity:0;
    pointer-events:none;
    transition:opacity .2s ease, transform .2s ease;
    z-index:50;
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}
  .toast.error{background:var(--danger);}
  .toast.success{background:var(--teal); color:var(--navy-deep);}
</style>
</head>
<body>

<div class="wrap">

  <div class="brand">
    <div class="mark">
      <svg viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="#F2A93B" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <h1>TaskTracker</h1>
  </div>

  <div class="auth-panel">

    <!-- LOGIN (left) -->
    <div class="login-side">
      <div class="login-eyebrow">Welcome back</div>
      <h2>Sign in</h2>
      <p class="sub">Access your boards, tasks and deadlines.</p>

      <div class="field">
        <label>Email</label>
        <input type="email" id="loginEmail" placeholder="you@example.com">
      </div>

      <div class="field">
        <label>Password</label>
        <input type="password" id="loginPassword" placeholder="••••••••">
      </div>

      <button class="btn-login" onclick="loginUser()" id="btnLogin">Sign in</button>
      <div class="login-error" id="loginError"></div>

      <div class="login-foot">
        <svg viewBox="0 0 24 24" fill="none"><path d="M12 2l8 4v6c0 5-3.4 8.4-8 10-4.6-1.6-8-5-8-10V6l8-4z" stroke="#8B93AA" stroke-width="1.6"/></svg>
        Your data stays on this workspace
      </div>
    </div>

    <!-- REGISTER (right) -->
    <div class="register-side">
      <div class="login-eyebrow">New here</div>
      <h2 id="formTitle">Create your account</h2>
      <p class="sub">A few details and you're set.</p>

      <input type="hidden" id="userId">

      <div class="field">
        <label>Name <span class="required">*</span></label>
        <input type="text" id="name">
        <div id="nameError" class="error"></div>
      </div>

      <div class="field">
        <label>Address</label>
        <textarea id="address" rows="2"></textarea>
      </div>

      <div class="field">
        <label>Email <span class="required">*</span></label>
        <input type="email" id="email">
        <div id="emailError" class="error"></div>
      </div>

      <div class="row2">
        <div class="field">
          <label>Password <span class="required">*</span></label>
          <input type="password" id="password">
          <div id="passwordError" class="error"></div>
        </div>

        <div class="field">
          <label>Date of birth</label>
          <input type="date" id="dob">
        </div>
      </div>

      <button class="btn-register" onclick="saveUser()" id="btnSave">Register</button>
    </div>

  </div>

  <div class="table-section">
    <div class="table-head">
      <h3>Registered users</h3>
      <span id="userCount">0 total</span>
    </div>

    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Email</th>
            <th>DOB</th>
            <th width="170">Action</th>
          </tr>
        </thead>
        <tbody id="signupTableBody"></tbody>
      </table>
    </div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>

  let users = [];

  function showToast(message, type) {
    const toast = document.getElementById("toast");
    toast.textContent = message;
    toast.className = "toast show " + (type || "");
    clearTimeout(showToast._t);
    showToast._t = setTimeout(() => {
      toast.classList.remove("show");
    }, 2600);
  }

  // ---------------- LOGIN ----------------

  async function loginUser() {

    document.getElementById("loginError").innerHTML = "";

    const email = document.getElementById("loginEmail").value.trim();
    const password = document.getElementById("loginPassword").value.trim();

    if (!email || !password) {
      document.getElementById("loginError").innerHTML =
        "Please enter both email and password";
      return;
    }

    const btn = document.getElementById("btnLogin");
    const originalText = btn.innerText;
    btn.innerText = "Signing in...";
    btn.disabled = true;

    try {

      const response = await fetch("/api/signup/login", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ email, password })
      });

      const result = await response.json();

      if (result.status) {
        showToast(result.message || "Login successful", "success");
        document.getElementById("loginPassword").value = "";
        window.location.href = "/Dashboard/Index";
        return;
      } else {
        document.getElementById("loginError").innerHTML =
          result.message || "Invalid email or password";
      }

    }
    catch (error) {
      console.error(error);
      document.getElementById("loginError").innerHTML =
        "Something went wrong. Please try again.";
    }
    finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  }

  // ---------------- REGISTER / CRUD ----------------

  async function saveUser() {

    document.getElementById("nameError").innerHTML = "";
    document.getElementById("emailError").innerHTML = "";
    document.getElementById("passwordError").innerHTML = "";

    let id = document.getElementById("userId").value;
    let name = document.getElementById("name").value.trim();
    let address = document.getElementById("address").value.trim();
    let email = document.getElementById("email").value.trim();
    let password = document.getElementById("password").value.trim();
    let dob = document.getElementById("dob").value;

    let valid = true;

    if (name === "") {
      document.getElementById("nameError").innerHTML = "Name is required";
      valid = false;
    }

    if (email === "") {
      document.getElementById("emailError").innerHTML = "Email is required";
      valid = false;
    }

    if (password.length < 6) {
      document.getElementById("passwordError").innerHTML =
        "Password must be at least 6 characters";
      valid = false;
    }

    if (!valid) return;

    const signup = { name, address, email, password, dob };

    try {

      let url = "/api/signup/add";
      let method = "POST";

      if (id) {
        url = `/api/signup/update/${id}`;
        method = "PUT";
      }

      const response = await fetch(url, {
        method: method,
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(signup)
      });

      const result = await response.json();

      showToast(result.message, result.status ? "success" : "error");

      if (result.status) {
        clearForm();
        loadUsers();
      }

    }
    catch (error) {
      console.error(error);
      showToast("Something went wrong", "error");
    }
  }

  async function loadUsers() {

    try {

      const response = await fetch("/api/signup/get");
      const result = await response.json();

      users = result.data || [];

      document.getElementById("userCount").innerText =
        users.length + (users.length === 1 ? " total" : " total");

      let rows = "";

      if (users.length === 0) {
        rows = `<tr class="empty-row"><td colspan="5">No users registered yet</td></tr>`;
      } else {
        users.forEach(user => {
          rows += `
            <tr>
              <td>${user.name ?? ""}</td>
              <td>${user.address ?? ""}</td>
              <td>${user.email}</td>
              <td>${new Date(user.dob).toLocaleDateString()}</td>
              <td>
                <button class="btn-sm btn-edit" onclick="editUser('${user.id}')">Edit</button>
                <button class="btn-sm btn-del" onclick="deleteUser('${user.id}')">Delete</button>
              </td>
            </tr>
          `;
        });
      }

      document.getElementById("signupTableBody").innerHTML = rows;

    }
    catch (error) {
      console.error(error);
    }
  }

  function editUser(id) {

    const user = users.find(x => x.id === id);
    if (!user) return;

    document.getElementById("userId").value = user.id;
    document.getElementById("name").value = user.name ?? "";
    document.getElementById("address").value = user.address ?? "";
    document.getElementById("email").value = user.email;
    document.getElementById("password").value = user.password;
    document.getElementById("dob").value = user.dob.split("T")[0];

    document.getElementById("btnSave").innerText = "Update user";
    document.getElementById("formTitle").innerText = "Update user";
  }

  async function deleteUser(id) {

    const confirmDelete = confirm("Are you sure you want to delete this user?");
    if (!confirmDelete) return;

    try {

      const response = await fetch(`/api/signup/delete/${id}`, { method: "DELETE" });
      const result = await response.json();

      showToast(result.message, result.status ? "success" : "error");
      loadUsers();

    }
    catch (error) {
      console.error(error);
      showToast("Delete failed", "error");
    }
  }

  function clearForm() {

    document.getElementById("userId").value = "";
    document.getElementById("name").value = "";
    document.getElementById("address").value = "";
    document.getElementById("email").value = "";
    document.getElementById("password").value = "";
    document.getElementById("dob").value = "";

    document.getElementById("btnSave").innerText = "Register";
    document.getElementById("formTitle").innerText = "Create your account";
  }

  window.onload = function () {
    loadUsers();
  };

</script>

</body>
</html>