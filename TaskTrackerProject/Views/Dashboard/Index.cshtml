

<style>

    body {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        min-height: 100vh;
    }

    .page-header {
        color: #fff;
        margin-bottom: 1.75rem;
    }

        .page-header h2 {
            font-weight: 700;
            letter-spacing: 0.4px;
            margin-bottom: 0.15rem;
        }

        .page-header p {
            opacity: 0.85;
            margin-bottom: 0;
        }

    .stat-card {
        border: none;
        border-radius: 16px;
        color: #fff;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
        height: 100%;
    }

        .stat-card .stat-icon {
            font-size: 1.6rem;
            opacity: 0.85;
        }

        .stat-card .stat-value {
            font-size: 1.9rem;
            font-weight: 700;
            line-height: 1;
        }

        .stat-card .stat-label {
            font-size: 0.85rem;
            opacity: 0.9;
        }

    .stat-total { background: linear-gradient(135deg, #6a11cb, #2575fc); }
    .stat-pending { background: linear-gradient(135deg, #f7971e, #ffd200); color: #3a2a00; }
    .stat-progress { background: linear-gradient(135deg, #00c6ff, #0072ff); }
    .stat-done { background: linear-gradient(135deg, #11998e, #38ef7d); }

    .main-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.22);
        background: #fff;
    }

        .main-card .card-header {
            background: #ffffff;
            border-bottom: 1px solid #eef0f5;
            padding: 1.5rem 1.75rem 1rem;
        }

    .btn-gradient {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        border: none;
        color: #fff;
        border-radius: 10px;
        padding: 0.6rem 1.2rem;
        font-weight: 600;
        letter-spacing: 0.3px;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(37, 117, 252, 0.35);
            color: #fff;
        }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid #dfe3ec;
        padding: 0.7rem 0.9rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #6a11cb;
            box-shadow: 0 0 0 0.2rem rgba(106, 17, 203, 0.15);
        }

    .table thead {
        background: #f5f6fa;
    }

    .badge-priority-high { background: #ff4d4f; }
    .badge-priority-medium { background: #ffa940; color: #3a2a00; }
    .badge-priority-low { background: #52c41a; }

    .badge-status-pending { background: #ffd200; color: #3a2a00; }
    .badge-status-progress { background: #0072ff; }
    .badge-status-completed { background: #38ef7d; color: #063d1f; }

    .task-row-completed td {
        text-decoration: line-through;
        opacity: 0.6;
    }

    .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        color: #fff;
        border-radius: 16px 16px 0 0;
    }

        .modal-header .btn-close {
            filter: invert(1);
        }
</style>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center page-header flex-wrap gap-2">
        <div>
            <h2><i class="bi bi-kanban-fill me-2"></i>Task Tracker Dashboard</h2>
            <p>Manage, track, and complete your tasks in one place</p>
        </div>
        <div>
            <button class="btn btn-light rounded-pill px-3" onclick="logout()">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-3">
            <div class="stat-card stat-total d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-value" id="statTotal">0</div>
                    <div class="stat-label">Total Tasks</div>
                </div>
                <i class="bi bi-list-task stat-icon"></i>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card stat-pending d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-value" id="statPending">0</div>
                    <div class="stat-label">Pending</div>
                </div>
                <i class="bi bi-hourglass-split stat-icon"></i>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card stat-progress d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-value" id="statProgress">0</div>
                    <div class="stat-label">In Progress</div>
                </div>
                <i class="bi bi-arrow-repeat stat-icon"></i>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card stat-done d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-value" id="statDone">0</div>
                    <div class="stat-label">Completed</div>
                </div>
                <i class="bi bi-check-circle stat-icon"></i>
            </div>
        </div>

    </div>

    <!-- Main Card -->
    <div class="card main-card">

        <div class="card-header">

            <div class="row g-2 align-items-center">

                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" id="txtSearch" class="form-control border-start-0" placeholder="Search tasks..." onkeyup="renderTasks()" />
                    </div>
                </div>

                <div class="col-md-3">
                    <select id="ddlFilterStatus" class="form-select" onchange="renderTasks()">
                        <option value="">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <select id="ddlFilterPriority" class="form-select" onchange="renderTasks()">
                        <option value="">All Priority</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>

                <div class="col-md-2 text-md-end">
                    <button class="btn btn-gradient w-100" data-bs-toggle="modal" data-bs-target="#taskModal" onclick="openAddModal()">
                        <i class="bi bi-plus-lg me-1"></i> Add Task
                    </button>
                </div>

            </div>

        </div>

        <div class="card-body table-responsive">

            <table class="table table-bordered table-hover align-middle" id="tblTasks">

                <thead>

                    <tr>
                        <th>SN</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Due Date</th>
                        <th width="220">Action</th>
                    </tr>

                </thead>

                <tbody></tbody>

            </table>

        </div>

    </div>

</div>

<!-- Add/Edit Task Modal -->
<div class="modal fade" id="taskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle"><i class="bi bi-plus-circle me-2"></i>Add Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtTaskId" />

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" id="txtTitle" class="form-control" placeholder="Task title" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea id="txtDescription" class="form-control" rows="3" placeholder="Task description"></textarea>
                </div>

                <div class="row g-2">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Priority</label>
                        <select id="ddlPriority" class="form-select">
                            <option value=0>Low</option>
                            <option value=1 selected>Medium</option>
                            <option value=2>High</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Status</label>
                        <select id="ddlStatus" class="form-select">
                            <option value=0>Pending</option>
                            <option value=1>In Progress</option>
                            <option value=2>Completed</option>
                        </select>
                    </div>

                </div>

                <div class="mb-3">
                    <label class="form-label">Due Date</label>
                    <input type="date" id="txtDueDate" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-gradient" id="btnSaveTask" onclick="saveTask()">Save Task</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <script>

        var tasks = [];
        var taskModal;

        $(document).ready(function () {

            taskModal = new bootstrap.Modal(document.getElementById('taskModal'));

            getTasks();

        });

        // ---------- CRUD OPERATIONS ----------

        function getTasks() {

            fetch('/api/ticket/get', {

                method: 'GET',

                headers: {
                    'Content-Type': 'application/json'
                }

            })
            .then(response => response.json())
            .then(data => {
                debugger;

                if (data.status) {

                    tasks = data.data;

                    renderTasks();

                }
                else {

                    alert(data.message);

                }

            })
            .catch(() => {

                alert("Unable to load tasks. Please check the API connection.");

            });

        }

        function openAddModal() {
            

            $("#txtTaskId").val("");
            $("#txtTitle").val("");
            $("#txtDescription").val("");
            $("#ddlPriority").val("Medium");
            $("#ddlStatus").val("Pending");
            $("#txtDueDate").val("");

            $("#modalTitle").html("<i class='bi bi-plus-circle me-2'></i>Add Task");
            $("#btnSaveTask").text("Save Task");

        }

        function openEditModal(id) {

            var item = tasks.find(x => x.id == id);

            if (item == null)
                return;

            $("#txtTaskId").val(item.id);
            $("#txtTitle").val(item.title);
            $("#txtDescription").val(item.description);
            $("#ddlPriority").val(item.priority);
            $("#ddlStatus").val(item.status);

            if (item.dueDate != null) {

                $("#txtDueDate").val(item.dueDate.substring(0, 10));

            }

            $("#modalTitle").html("<i class='bi bi-pencil-square me-2'></i>Edit Task");
            $("#btnSaveTask").text("Update Task");

            taskModal.show();

        }

        function saveTask() {

    var title = $("#txtTitle").val();

    if (title == "") {
        alert("Title is required");
        return;
    }

    var isUpdate = $("#txtTaskId").val() != "";

    var model = {
        Title: title,
        Description: $("#txtDescription").val(),
        Priority: parseInt($("#ddlPriority").val()),
        Status: parseInt($("#ddlStatus").val()),
        DueDate: $("#txtDueDate").val()
    };

    if (isUpdate) {
        model.Id = $("#txtTaskId").val();
    }

    fetch(isUpdate ? '/api/ticket/update' : '/api/ticket/add', {

        method: 'POST',

        headers: {
            'Content-Type': 'application/json'
        },

        body: JSON.stringify(model)

    })
    .then(response => response.json())
    .then(data => {

        if (data.status) {
            taskModal.hide();
            getTasks();
        }
        else {
            alert(data.message);
        }

    })
    .catch(() => {
        alert("Unable to save the task.");
    });
}
        function updateStatus(id, newStatus) {

            var model = {
                Id: id,
                Status: newStatus
            };

            fetch('/api/ticket/updateStatus', {

                method: 'POST',

                headers: {
                    'Content-Type': 'application/json'
                },

                body: JSON.stringify(model)

            })
            .then(response => response.json())
            .then(data => {

                if (data.status) {

                    getTasks();

                }
                else {

                    alert(data.message);

                }

            });

        }

        function deleteTask(id) {

            if (!confirm("Are you sure you want to delete this task?"))
                return;

            fetch('/api/ticket/delete?id=' + id, {

                method: 'GET'

            })
            .then(response => response.json())
            .then(data => {

                if (data.status) {

                    getTasks();

                }
                else {

                    alert(data.message);

                }

            });

        }

        // ---------- RENDERING ----------

        function renderTasks() {

            var search = $("#txtSearch").val().toLowerCase();
            var filterStatus = $("#ddlFilterStatus").val();
            var filterPriority = $("#ddlFilterPriority").val();

            var filtered = tasks.filter(function (t) {

                var matchesSearch = t.title.toLowerCase().includes(search) ||
                    (t.description != null && t.description.toLowerCase().includes(search));

                var matchesStatus = filterStatus == "" || t.status == filterStatus;
                var matchesPriority = filterPriority == "" || t.priority == filterPriority;

                return matchesSearch && matchesStatus && matchesPriority;

            });

            $("#tblTasks tbody").empty();

            $.each(filtered, function (index, item) {

                var dueDate = item.dueDate != null ? item.dueDate.substring(0, 10) : "-";

                var priorityBadge = "badge-priority-" + item.priority;
                var statusBadge = "badge-status-" + item.status;
                var rowClass = item.status == 2 ? "task-row-completed" : "";

             var priorityDropdown =
              "<select class='form-select form-select-sm' style='width:130px; display:inline-block;' onchange='updatePriority(\"" + item.id + "\", this.value)'>" +
               "<option value='0'" + (item.priority == 0 ? " selected" : "") + ">Low</option>" +
                "<option value='1'" + (item.priority == 1 ? " selected" : "") + ">Medium</option>" +
                 "<option value='2'" + (item.priority == 2 ? " selected" : "") + ">High</option>" +
                 "</select>";

                var statusDropdown =
                    "<select class='form-select form-select-sm' style='width:130px; display:inline-block;' onchange='updateStatus(\"" + item.id + "\", this.value)'>" +
                    "<option value=0" + (item.status == 0 ? " selected" : "") + ">Pending</option>" +
                    "<option value=1" + (item.status == 1 ? " selected" : "") + ">In Progress</option>" +
                    "<option value=2" + (item.status == 2 ? " selected" : "") + ">Completed</option>" +
                    "</select>";

                $("#tblTasks tbody").append(

                    "<tr class='" + rowClass + "'>" +
                    "<td>" + (index + 1) + "</td>" +
                    "<td>" + item.title + "</td>" +
                    "<td>" + (item.description || "") + "</td>" +
                    "<td>" + priorityDropdown + "</td>" +
                    "<td>" + statusDropdown + "</td>" +
                    "<td>" + dueDate + "</td>" +
                    "<td>" +
                    "<button class='btn btn-warning btn-sm me-1' onclick='openEditModal(\"" + item.id + "\")'><i class='bi bi-pencil'></i></button>" +
                    "<button class='btn btn-danger btn-sm' onclick='deleteTask(\"" + item.id + "\")'><i class='bi bi-trash'></i></button>" +
                    "</td>" +
                    "</tr>"

                );

            });

            updateStats();

        }

        function updateStats() {

            $("#statTotal").text(tasks.length);
            $("#statPending").text(tasks.filter(t => t.status == "Pending").length);
            $("#statProgress").text(tasks.filter(t => t.status == "In Progress").length);
            $("#statDone").text(tasks.filter(t => t.status == "Completed").length);

        }

        function logout() {

            fetch('/api/account/logout', { method: 'POST' })
                .finally(() => {
                    window.location.href = "/";
                });

        }

    </script>

}
